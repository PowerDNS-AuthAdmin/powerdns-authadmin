# =============================================================================
# .env.example — exhaustive list of every environment variable lib/env.ts
# validates at boot. The app refuses to start on a missing/invalid required
# variable (misconfiguration becomes a clear startup error, not a runtime
# surprise).
#
# This file doubles as the env_file for the MINIMAL-DEMO STACK (docker-compose.yml):
# it's read directly, so `docker compose up -d --build` works with no extra
# steps. The values below are a working SQLite demo.
#
#   ⚠️  The APP_SECRET_KEY / APP_ENCRYPTION_KEY here are THROWAWAY demo values
#       committed to the repo — anyone can read them. The BOOTSTRAP_ADMIN
#       password is "change-me-now". Before exposing this to anything real:
#         cp .env.example .env
#         openssl rand -base64 32   # → APP_SECRET_KEY
#         openssl rand -base64 32   # → APP_ENCRYPTION_KEY
#       set a strong BOOTSTRAP_ADMIN_PASSWORD, and point env_file at .env.
#
# Any variable also accepts a `_FILE` suffix: instead of an inline value, point
# at a file whose contents are the value (Docker / Kubernetes secrets):
#   APP_SECRET_KEY_FILE=/run/secrets/app_key
# =============================================================================


# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------

NODE_ENV=production
# PORT=3000
# Public URL the app is served from. Used in emails, OAuth redirect URIs, and
# CSP origin checks. Absolute URL, no trailing slash.
APP_URL=http://localhost:3000
# Log level: trace | debug | info | warn | error | fatal. Default: info.
LOG_LEVEL=info


# -----------------------------------------------------------------------------
# Secrets — REQUIRED. APP_SECRET_KEY ≥32 chars; APP_ENCRYPTION_KEY must be
# base64 that decodes to ≥32 bytes (AES-256 key). Generate each with:
#   openssl rand -base64 32
# ⚠️ THE VALUES BELOW ARE PUBLIC DEMO KEYS — regenerate before any real use.
# -----------------------------------------------------------------------------

APP_SECRET_KEY=kQNFuuPJLRHE1qsbUgXQDMAcgsg2kxVip34yE9ydwS8=
APP_ENCRYPTION_KEY=n+ZccvIUcG6XoJ2qoUtaPtk7tme1n5NbT3QXkiHBs4M=


# -----------------------------------------------------------------------------
# Database
#
# Driver + migrations directory are chosen from the URL prefix (ADR-0011):
#   SQLite:    file:/path/to/db.sqlite   (absolute)  |  file:./db.sqlite (relative)
#   Postgres:  postgres://user:password@host:port/database
#
# SQLite suits single-instance evaluation / homelab / edge. Use Postgres for
# production multi-instance + write concurrency. Switching dialects is a fresh
# install — the two schema histories don't share migrations.
# -----------------------------------------------------------------------------

# Minimal-demo default: SQLite in the app container's /data volume.
DATABASE_URL=file:/data/powerdns_authadmin.db
# Postgres alternative (see the docker-compose-*.yml topology stacks):
# DATABASE_URL=postgres://pdns:pdns@postgres:5432/powerdns_authadmin

# Connection pool size (Postgres only). Default 10.
# DATABASE_POOL_SIZE=10

# Boot steps run by docker/entrypoint.mjs. All default to ON when unset; set to
# "false" to skip (e.g. when CI/CD runs migrations as a separate step).
# MIGRATE_ON_BOOT=true
# SEED_ON_BOOT=true


# -----------------------------------------------------------------------------
# Bootstrap admin
#
# When set, the boot seed ensures a SuperAdmin with this email exists (created
# with "must change password on next login"). Password must be ≥12 chars.
# -----------------------------------------------------------------------------

BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=change-me-now


# -----------------------------------------------------------------------------
# First-boot provisioning (ADR-0012)
#
# When PROVISIONING_FILE points at a YAML file inside the container, the
# entrypoint applies it once and writes a `provisioned_at` settings row. The
# minimal-demo stack mounts provisioning.minimal-demo.yaml here (registers the
# bundled PowerDNS + generates 10 demo zones, 10 records each).
# -----------------------------------------------------------------------------

PROVISIONING_FILE=/etc/powerdns-authadmin/provisioning.yaml
PROVISION_ON_BOOT=true


# -----------------------------------------------------------------------------
# PowerDNS connectivity (SSRF guard)
# -----------------------------------------------------------------------------

# Accept private-network PDNS destinations. Default: permissive in dev, strict
# in production. Required "true" for the in-container PDNS on the compose net.
APP_PDNS_ALLOW_PRIVATE_NETWORKS=true
# Accept http:// PDNS base URLs (default requires https in production). Needed
# for the demo's http://pdns:8081 backend. Both flags must be opt-in.
APP_PDNS_ALLOW_INSECURE_HTTP=true


# -----------------------------------------------------------------------------
# OIDC issuer connectivity (SSRF guard — mirrors the PDNS pair above)
# -----------------------------------------------------------------------------
# The OIDC issuer/discovery URL is operator-supplied and fetched server-side
# (provider test + live discovery), so it runs through the same outbound-URL
# guard as PDNS backends. Defaults: permissive in dev, strict in production.
# Link-local / cloud-metadata (169.254.0.0/16) is ALWAYS blocked regardless.

# Accept an OIDC issuer that resolves to a private-network address (internal IdP).
# APP_OIDC_ALLOW_PRIVATE_NETWORKS=false
# Accept an http:// issuer URL (default requires https in production). Set only
# for an internal IdP without TLS at the endpoint. Both flags must be opt-in.
# APP_OIDC_ALLOW_INSECURE_HTTP=false


# -----------------------------------------------------------------------------
# Sessions
# -----------------------------------------------------------------------------

# Session lifetime in seconds. Default 43200 (12 hours).
# SESSION_TTL_SECONDS=43200
# Cookie domain. Derived from APP_URL when unset; set only for cross-subdomain SSO.
# COOKIE_DOMAIN=example.com


# -----------------------------------------------------------------------------
# Local authentication (email + password)
# -----------------------------------------------------------------------------

# Enable local accounts. Default true.
# LOCAL_AUTH_ENABLED=true

# --- Public self-service signup ---
# Off by default. When false the /signup page and POST /api/auth/signup both
# return 404 — the feature does not exist for the deployment. When true:
#   - visitors register at /signup with email + password (Argon2id, min 12 chars);
#   - the account is created UNVERIFIED and CANNOT log in until the email is
#     verified (any unverified local account is blocked from login while signup
#     is on — verify via the link, then sign in);
#   - the verification link is EMAILED when SMTP is configured below, otherwise
#     it is recorded in the audit log (action `auth.email.verify.sent`) for the
#     operator to share out-of-band. Configure SMTP_* for real delivery.
# SIGNUP_ENABLED=false
# Role (slug) every signup receives. MUST be low-privilege — the seed step
# refuses to boot when this is missing or admin-equivalent (holds user/role/
# settings/server/audit/etc permissions). Default: read-only.
# SIGNUP_DEFAULT_ROLE=read-only
# Comma-separated email-domain allow-list for signups. Empty/unset = any domain.
# Exact-domain match, case-insensitive. Out-of-list addresses are rejected.
# SIGNUP_ALLOWED_EMAIL_DOMAINS=example.com,contractors.example.com


# -----------------------------------------------------------------------------
# OIDC SSO (env-driven single provider; multi-provider via the admin UI)
# -----------------------------------------------------------------------------

# OIDC_ENABLED=false
# Stable slug used in the callback URL: /api/auth/oidc/<id>/callback
# OIDC_PROVIDER_ID=google
# OIDC_PROVIDER_NAME=Google
# Issuer URL — the app fetches its .well-known discovery doc.
# OIDC_ISSUER_URL=https://accounts.google.com
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# Space-separated scopes. Default: "openid profile email"
# OIDC_SCOPES=openid profile email
# Claim mapping (defaults are the standard claims).
# OIDC_CLAIM_USERNAME=email
# OIDC_CLAIM_EMAIL=email
# OIDC_CLAIM_NAME=name
# Comma-separated email-domain allow-list for NEW OIDC users. Empty = no limit.
# OIDC_ALLOWED_EMAIL_DOMAINS=example.com,contractors.example.com


# -----------------------------------------------------------------------------
# Captcha — Cloudflare Turnstile (optional)
#
# With TURNSTILE_SECRET_KEY set, login/forgot/change-password require a verified
# token. With TURNSTILE_SITE_KEY set, the forms render the widget. Set both for
# production public login; leave unset otherwise.
# -----------------------------------------------------------------------------

# TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=


# -----------------------------------------------------------------------------
# Email / SMTP (transactional mail: verify-email, password reset, email change)
#
# Optional. With SMTP_HOST unset, mail is skipped (logged). When set, the rest
# must be coherent (validated in lib/env.ts). Encryption picks ONE shape:
#   • SMTP_SECURE=true             implicit TLS (SMTPS, port 465)
#   • SMTP_STARTTLS=required       STARTTLS or refuse to send (port 587)
#   • SMTP_STARTTLS=opportunistic  STARTTLS if offered (default)
#   • SMTP_STARTTLS=disabled       plaintext only (local fakemail)
# Setting SMTP_SECURE=true AND SMTP_STARTTLS=required is rejected.
# Auth is optional: omit BOTH SMTP_USERNAME + SMTP_PASSWORD for an IP-allow-listed
# relay (setting only one is rejected).
# -----------------------------------------------------------------------------

# SMTP_HOST=smtp.example.com
# SMTP_PORT=587                          # default: 465 if SMTP_SECURE=true, 587 if STARTTLS=required, else 25
# SMTP_SECURE=false                      # true = implicit TLS (port 465); for port 587 keep false + STARTTLS
# SMTP_STARTTLS=opportunistic            # required | opportunistic | disabled
# SMTP_USERNAME=                         # leave blank for an unauthenticated relay
# SMTP_PASSWORD=                         # (or SMTP_PASSWORD_FILE for docker/k8s secrets)
# SMTP_FROM=no-reply@example.com         # required when SMTP_HOST is set
# SMTP_FROM_NAME=PowerDNS-AuthAdmin      # optional display name
# SMTP_TLS_REJECT_UNAUTHORIZED=true      # false ONLY for local fakemail with self-signed certs
# SMTP_TIMEOUT_MS=10000                  # per-stage timeout (connection / greeting / socket)


# -----------------------------------------------------------------------------
# Redis (optional — for horizontal scale, replicas > 1)
#
# When set, auth rate limiting, the realtime SSE event-bus, and one-time reveal
# tokens coordinate across replicas (sessions are already shared via Postgres).
# Each falls back to its in-process path when REDIS_URL is unset or a command
# fails, so single-node deployments need no Redis. See the README
# "High availability" section and ADR-0016.
# -----------------------------------------------------------------------------

# REDIS_URL=redis://localhost:6379


# -----------------------------------------------------------------------------
# Telemetry (off by default — opt in)
# -----------------------------------------------------------------------------

# OTEL_EXPORTER_OTLP_ENDPOINT=
# Expose GET /metrics (Prometheus). Default false.
# METRICS_ENABLED=true
# Optional bearer token gating /metrics (≥16 chars). Unset = open (rely on
# network ACLs). Generate with: openssl rand -hex 32
# METRICS_TOKEN=
