# Pin all installs to exact versions.
# Reasoning: a dependency surprise on `npm install` should never break a contributor's first run.
# Renovate (see renovate.json) batches and PR-reviews updates instead.
save-exact=true

# Refuse to install if the contributor's Node version doesn't match `engines` in package.json.
# This is a safety net for the Node 22 LTS requirement.
engine-strict=true

# Audit on install; fail on high/critical findings.
# CI runs `npm audit --audit-level=high --omit=dev` as a stricter gate.
audit=true

# Make the install log less noisy.
fund=false
