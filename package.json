{
  "name": "powerdns-authadmin",
  "version": "1.0.1",
  "private": true,
  "description": "Modern, self-hosted DNS administration UI for PowerDNS — multi-team RBAC, real audit, real SSO. From-scratch rebuild of PowerDNS-Admin in Node.js + TypeScript.",
  "license": "MIT",
  "homepage": "https://github.com/jseifeddine/powerdns-authadmin",
  "bugs": "https://github.com/jseifeddine/powerdns-authadmin/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/jseifeddine/powerdns-authadmin"
  },
  "engines": {
    "node": ">=24.0.0 <25.0.0",
    "npm": ">=10.0.0"
  },
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:integration": "tests/integration/run.sh",
    "test:integration:bare": "vitest run --config vitest.config.integration.ts",
    "test:e2e": "playwright test",
    "db:generate": "drizzle-kit generate",
    "db:generate:sqlite": "drizzle-kit generate --config=drizzle.sqlite.config.ts",
    "db:migrate": "NODE_OPTIONS=--conditions=react-server tsx scripts/migrate.ts",
    "db:migrate:pg": "drizzle-kit migrate",
    "db:migrate:sqlite": "drizzle-kit migrate --config=drizzle.sqlite.config.ts",
    "db:studio": "drizzle-kit studio",
    "db:studio:sqlite": "drizzle-kit studio --config=drizzle.sqlite.config.ts",
    "db:seed": "NODE_OPTIONS=--conditions=react-server tsx scripts/seed.ts",
    "provision": "NODE_OPTIONS=--conditions=react-server tsx scripts/provision.ts",
    "audit:strict": "npm audit --audit-level=high --omit=dev",
    "validate": "npm run lint && npm run typecheck && npm run format:check && npm run test"
  },
  "dependencies": {
    "@casl/ability": "7.0.0",
    "@casl/react": "7.0.0",
    "@node-rs/argon2": "2.0.2",
    "@tanstack/react-table": "8.21.3",
    "better-sqlite3": "12.10.0",
    "client-only": "0.0.1",
    "diff": "9.0.0",
    "drizzle-orm": "0.45.2",
    "echarts": "6.1.0",
    "echarts-for-react": "3.0.6",
    "jose": "6.2.3",
    "js-yaml": "4.1.1",
    "lucide-react": "1.16.0",
    "next": "16.2.6",
    "nodemailer": "8.0.7",
    "openid-client": "6.8.4",
    "pg": "8.21.0",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "qrcode": "1.5.4",
    "react": "19.2.6",
    "react-datepicker": "9.1.0",
    "react-diff-viewer-continued": "4.2.2",
    "react-dom": "19.2.6",
    "server-only": "0.0.1",
    "tsx": "4.22.3",
    "undici": "8.3.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.60.0",
    "@tailwindcss/postcss": "4.3.0",
    "@types/better-sqlite3": "7.6.13",
    "@types/js-yaml": "4.0.9",
    "@types/node": "24.12.4",
    "@types/nodemailer": "8.0.0",
    "@types/pg": "8.20.0",
    "@types/qrcode": "1.5.6",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/coverage-v8": "4.1.7",
    "@vitest/ui": "4.1.7",
    "drizzle-kit": "0.31.10",
    "eslint": "10.4.0",
    "eslint-config-next": "16.2.6",
    "eslint-plugin-import-x": "4.16.2",
    "postcss": "8.5.15",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "0.8.0",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.4",
    "vitest": "4.1.7"
  },
  "overrides": {
    "comment": "Add transitive-dep overrides here when patching CVEs that upstream hasn't released. Each entry should have a tracking issue."
  }
}
